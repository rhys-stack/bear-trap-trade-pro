# =====================================================================
# Bear Trap Trade Pro — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =====================================================================

# -------------------------------------------------------
# TRADING MODE
# Set to true only when you are ready to go live.
# Paper trading is the default and the safe state.
# -------------------------------------------------------
LIVE_TRADING=false

# Simulated account balance used in paper mode (USDT)
PAPER_BALANCE=10000

# -------------------------------------------------------
# WEBHOOK SECURITY
# Set a random secret (e.g. openssl rand -hex 32).
# Include in your TradingView webhook URL:
#   https://your-app.railway.app/webhook?secret=YOUR_SECRET
# -------------------------------------------------------
WEBHOOK_SECRET=change-me-to-a-random-secret

# -------------------------------------------------------
# BITGET API (required only when LIVE_TRADING=true)
# Create keys at: https://www.bitget.com/en/account/newapi
# Permissions needed: Trade (no withdrawal permission).
# -------------------------------------------------------
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_API_PASSPHRASE=
BROKER_BASE_URL=https://api.bitget.com

# -------------------------------------------------------
# RISK MANAGEMENT
# -------------------------------------------------------
# Percentage of account to risk per trade
RISK_PER_TRADE=2

# Stop bot opening new trades once daily loss exceeds this %
MAX_DAILY_LOSS=6

# Stop bot opening new trades once weekly loss exceeds this %
MAX_WEEKLY_LOSS=10

# Comma-separated list of allowed symbols (USDT-M only)
SYMBOL_ALLOWLIST=XRPUSDT,BTCUSDT,ETHUSDT,SOLUSDT

# -------------------------------------------------------
# EMAIL ALERTS
# Choose ONE provider: SMTP or Resend.
# -------------------------------------------------------
EMAIL_FROM=alerts@yourdomain.com
EMAIL_TO=you@yourdomain.com

# Option A — SMTP (e.g. Gmail, SendGrid, Mailgun)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password

# Option B — Resend (https://resend.com) — leave SMTP fields blank
RESEND_API_KEY=

# -------------------------------------------------------
# SERVER
# -------------------------------------------------------
PORT=3000
