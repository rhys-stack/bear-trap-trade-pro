//@version=5
indicator("Bear Trap Trade Pro", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// ── INPUTS ──────────────────────────────────────────────────────────
i_pivotLeft      = input.int(10,     "Pivot Left",           minval=2,  maxval=50,  group="Bear Trap")
i_pivotRight     = input.int(10,     "Pivot Right",          minval=2,  maxval=50,  group="Bear Trap")
i_allowWick      = input.bool(true,  "Allow Wick Sweep",                             group="Bear Trap")
i_minScore       = input.int(2,      "Min Score (1-5)",      minval=1,  maxval=5,   group="Bear Trap")
i_htfFilter      = input.bool(false,       "HTF Filter",                             group="Filters")
i_htfTf          = input.timeframe("240",  "HTF Timeframe",                          group="Filters")
i_ema200Filter   = input.bool(true,        "EMA 200 Filter",                         group="Filters")
i_minRR          = input.float(1.5,  "Min R:R",              minval=0.5, step=0.1,  group="Filters")
i_maxSlAtr       = input.float(2.0,  "Max Stop (ATR x)",     minval=0.5, step=0.1,  group="Filters")
i_atrLen         = input.int(14,     "ATR Length",           minval=1,               group="Levels")
i_atrSlBuf       = input.float(0.3,  "ATR SL Buffer",        minval=0.1, step=0.1,  group="Levels")
i_tp1R           = input.float(1.0,  "TP1 R-Multiple",       minval=0.5, step=0.1,  group="Levels")
i_tp2R           = input.float(2.0,  "TP2 R-Multiple",       minval=1.0, step=0.1,  group="Levels")
i_maxBarsInTrade = input.int(50,     "Max Bars in Trade",    minval=5,  maxval=200,  group="Risk")
i_maxLossPct     = input.float(1.5,  "Max Loss Cap %",       minval=0.1, maxval=10,  group="Risk")
i_volLen         = input.int(20,     "Vol Avg Length",       minval=5,               group="Confluence")
i_volMult        = input.float(1.5,  "Vol Spike Mult",       minval=1.0, step=0.1,  group="Confluence")
i_showSess       = input.bool(true,  "Show Sessions",                                group="Display")
i_showWeekend    = input.bool(true,  "Show Weekend",                                 group="Display")
i_funding        = input.float(0.0,  "Funding Rate %",       step=0.001,             group="Display")
i_acctSize       = input.float(1000.0,"Account (USDT)",      minval=1,               group="Display")
i_riskPct        = input.float(2.0,  "Risk %",               minval=0.1, maxval=10,  group="Display")
i_leverage       = input.int(10,     "Leverage (liq)",       minval=1, maxval=125,   group="Display")
i_orderType      = input.string("Limit","Order Type", options=["Limit","Market"],    group="Display")

// ── CORE INDICATORS ─────────────────────────────────────────────────
atr    = ta.atr(i_atrLen)
ema200 = ta.ema(close, 200)
volAvg = ta.sma(volume, i_volLen)

htfClose   = request.security(syminfo.tickerid, i_htfTf, close[1],             lookahead=barmerge.lookahead_off)
htfEma200  = request.security(syminfo.tickerid, i_htfTf, ta.ema(close,200)[1], lookahead=barmerge.lookahead_off)
htfBullish = htfClose > htfEma200

// ── PIVOT DETECTION ─────────────────────────────────────────────────
rawPivotLow  = ta.pivotlow(low,   i_pivotLeft, i_pivotRight)
rawPivotHigh = ta.pivothigh(high, i_pivotLeft, i_pivotRight)

var float lastPivotLow  = na
var int   lastPivotBar  = na
var float lastPivotHigh = na

if not na(rawPivotLow)
    lastPivotLow := rawPivotLow
    lastPivotBar := bar_index - i_pivotRight

if not na(rawPivotHigh)
    lastPivotHigh := rawPivotHigh

// ── CVD PROXY ───────────────────────────────────────────────────────
cvdProxy(o, h, l, c, v) =>
    r = h - l
    r > 0.0 ? ((c - l) - (h - c)) / r * v : 0.0

cvd1 = cvdProxy(open[1], high[1], low[1], close[1], volume[1])
cvd2 = cvdProxy(open[2], high[2], low[2], close[2], volume[2])

// ── BEAR TRAP DETECTION ─────────────────────────────────────────────
validPivot    = not na(lastPivotLow) and bar_index > lastPivotBar + 1
wickSweep     = validPivot and low[1]   < lastPivotLow and close[1] > lastPivotLow
closeSweep    = validPivot and close[2] < lastPivotLow and close[1] > lastPivotLow
bearTrapSetup = (i_allowWick ? wickSweep : closeSweep) and close > open and close > lastPivotLow

ema200Pass = close > ema200
htfPass    = not i_htfFilter    or htfBullish
ema200Gate = not i_ema200Filter or ema200Pass

scoreRaw = (htfBullish ? 1 : 0) + (ema200Pass ? 1 : 0) + (volume[1] > volAvg[1] * i_volMult ? 1 : 0) + (atr > atr[1] ? 1 : 0) + (low[1] < low[2] and cvd1 > cvd2 ? 1 : 0)
score    = math.max(0, scoreRaw - (i_funding > 0.001 ? 1 : 0))

// ── PRE-ENTRY FILTERS ───────────────────────────────────────────────
prospSl   = low[1] - atr * i_atrSlBuf
prospRisk = close - prospSl
prospTp1  = not na(lastPivotHigh) and lastPivotHigh > close and lastPivotHigh < close + prospRisk * 2.0 ? lastPivotHigh : close + prospRisk * i_tp1R
atrFilter = prospRisk > 0 and prospRisk <= i_maxSlAtr * atr
rrFilter  = prospRisk > 0 and (prospTp1 - close) / prospRisk >= i_minRR

bearTrapSignal = bearTrapSetup and score >= i_minScore and htfPass and ema200Gate and atrFilter and rrFilter

// ── TRADE STATE MACHINE ─────────────────────────────────────────────
var float  entryPrice   = na
var float  stopLevel    = na
var float  tp1Level     = na
var float  tp2Level     = na
var float  tp3Level     = na
var bool   inTrade      = false
var int    lastSigBar   = na
var string sigStatus    = "WAIT"
var bool   tp1Fired     = false
var bool   tp2Fired     = false
var int    tradeBarNum  = 0

// One-shot per-bar signals (cleared each bar, set inside state machine)
var bool   tp1Signal    = false
var bool   tp2Signal    = false
var bool   exitSignal   = false

tp1Signal := false
tp2Signal := false
exitSignal := false

if bearTrapSignal and not inTrade
    entryPrice  := close
    stopLevel   := low[1] - atr * i_atrSlBuf
    float risk   = entryPrice - stopLevel
    tp1Level    := not na(lastPivotHigh) and lastPivotHigh > entryPrice and lastPivotHigh < entryPrice + risk * 2.0 ? lastPivotHigh : entryPrice + risk * i_tp1R
    tp2Level    := not na(lastPivotHigh) and lastPivotHigh > tp1Level ? lastPivotHigh : entryPrice + risk * i_tp2R
    tp3Level    := entryPrice + risk * 3.0
    inTrade     := true
    lastSigBar  := bar_index
    sigStatus   := "BUY"
    tp1Fired    := false
    tp2Fired    := false
    tradeBarNum := 0

if inTrade
    tradeBarNum += 1

    // TP1 first fire — move stop to breakeven
    if not tp1Fired and not na(tp1Level) and high >= tp1Level
        tp1Fired  := true
        tp1Signal := true
        stopLevel := entryPrice

    // TP2 first fire — activate trailing stop
    if tp1Fired and not tp2Fired and not na(tp2Level) and high >= tp2Level
        tp2Fired  := true
        tp2Signal := true

    // Trailing stop: ratchet under higher lows after TP2
    if tp2Fired
        float trail = low[1] - atr * i_atrSlBuf
        if trail > stopLevel
            stopLevel := trail

    // Hard stop — no exceptions, checked every bar
    if not na(stopLevel) and low <= stopLevel
        exitSignal  := true
        inTrade     := false
        sigStatus   := "EXIT"
        entryPrice  := na
        stopLevel   := na
        tp1Level    := na
        tp2Level    := na
        tp3Level    := na
        tp1Fired    := false
        tp2Fired    := false
        tradeBarNum := 0
    // TP3 full exit
    else if not na(tp3Level) and high >= tp3Level
        exitSignal  := true
        inTrade     := false
        sigStatus   := "EXIT"
        entryPrice  := na
        stopLevel   := na
        tp1Level    := na
        tp2Level    := na
        tp3Level    := na
        tp1Fired    := false
        tp2Fired    := false
        tradeBarNum := 0
    // Max bars timeout
    else if tradeBarNum >= i_maxBarsInTrade
        exitSignal  := true
        inTrade     := false
        sigStatus   := "EXIT"
        entryPrice  := na
        stopLevel   := na
        tp1Level    := na
        tp2Level    := na
        tp3Level    := na
        tp1Fired    := false
        tp2Fired    := false
        tradeBarNum := 0
    else
        sigStatus := "IN TRADE"

// ── DERIVED VALUES ──────────────────────────────────────────────────
riskAmt = inTrade ? math.abs(entryPrice - stopLevel) : na
effRisk = math.min(i_riskPct, i_maxLossPct)
rrRatio = not na(riskAmt) and riskAmt > 0 ? math.abs(tp2Level - entryPrice) / riskAmt : na
posSize = not na(riskAmt) and riskAmt > 0 ? i_acctSize * (effRisk / 100.0) / riskAmt : na
liqEst  = inTrade ? entryPrice * (1.0 - 0.9 / i_leverage) : na

utcH      = hour(time, "UTC")
utcM      = minute(time, "UTC")
dow       = dayofweek(time, "UTC")
isWeekend = (dow == dayofweek.saturday and utcH >= 21) or (dow == dayofweek.sunday and utcH < 21)

// ── OVERLAYS ────────────────────────────────────────────────────────
plot(ema200,       "EMA 200",   color=color.new(color.yellow, 0), linewidth=2)
plot(lastPivotLow, "Swing Low", color=color.new(color.red, 60), style=plot.style_cross)

if bearTrapSignal
    label.new(bar_index, low[1] * 0.9995, "TRAP " + str.tostring(score) + "/5",
              style=label.style_label_up, color=color.new(color.green, 15), textcolor=color.white, size=size.small)

if not na(rawPivotLow)
    label.new(bar_index - i_pivotRight, rawPivotLow, ".",
              style=label.style_label_up, color=color.new(color.red, 40), textcolor=color.red, size=size.tiny)

if not na(rawPivotHigh)
    label.new(bar_index - i_pivotRight, rawPivotHigh, ".",
              style=label.style_label_down, color=color.new(color.teal, 40), textcolor=color.teal, size=size.tiny)

var line ln_entry = na
var line ln_sl    = na
var line ln_tp1   = na
var line ln_tp2   = na
var line ln_tp3   = na

if bearTrapSignal and not inTrade[1]
    if not na(ln_entry)
        line.delete(ln_entry)
    if not na(ln_sl)
        line.delete(ln_sl)
    if not na(ln_tp1)
        line.delete(ln_tp1)
    if not na(ln_tp2)
        line.delete(ln_tp2)
    if not na(ln_tp3)
        line.delete(ln_tp3)
    e = bar_index + 60
    ln_entry := line.new(bar_index, entryPrice, e, entryPrice, color=color.blue,  width=2, style=line.style_dashed)
    ln_sl    := line.new(bar_index, stopLevel,  e, stopLevel,  color=color.red,   width=2, style=line.style_dashed)
    ln_tp1   := line.new(bar_index, tp1Level,   e, tp1Level,   color=color.lime,  width=1, style=line.style_dashed)
    ln_tp2   := line.new(bar_index, tp2Level,   e, tp2Level,   color=color.green, width=2, style=line.style_dashed)
    ln_tp3   := line.new(bar_index, tp3Level,   e, tp3Level,   color=color.teal,  width=1, style=line.style_dotted)

if i_showSess
    if utcH == 0 and utcM == 0
        label.new(bar_index, high, "Asia",   style=label.style_label_down, color=color.new(color.blue,   65), textcolor=color.white, size=size.tiny)
    if utcH == 8 and utcM == 0
        label.new(bar_index, high, "London", style=label.style_label_down, color=color.new(color.orange, 65), textcolor=color.white, size=size.tiny)
    if utcH == 13 and utcM == 0
        label.new(bar_index, high, "NY",     style=label.style_label_down, color=color.new(color.purple, 65), textcolor=color.white, size=size.tiny)

var label lbl_weekend = na
if i_showWeekend and isWeekend and barstate.islast
    label.delete(lbl_weekend)
    lbl_weekend := label.new(bar_index, high, "WEEKEND LOW LIQ",
                  style=label.style_label_down, color=color.new(color.red, 25), textcolor=color.white, size=size.small)

// ── DASHBOARD ───────────────────────────────────────────────────────
var table dash = table.new(position.top_right, 2, 23,
     bgcolor=color.new(color.black, 25), border_color=color.new(color.gray, 50),
     border_width=1, frame_color=color.new(color.gray, 30), frame_width=1)

f_cell(col, row, txt, bg, tc) =>
    table.cell(dash, col, row, txt, bgcolor=bg, text_color=tc, text_size=size.small)

sBg(s) =>
    s == "BUY" ? color.new(color.green, 15) : s == "IN TRADE" ? color.new(color.blue, 20) : s == "EXIT" ? color.new(color.red, 20) : color.new(color.gray, 45)

if barstate.islast
    H  = color.new(color.navy,   20)
    R  = color.new(color.black,  40)
    OK = color.new(color.green,  25)
    FL = color.new(color.red,    30)
    WN = color.new(color.orange, 25)
    W  = color.white
    S  = color.silver

    f_cell(0,  0, "BEAR TRAP TRADE PRO",  H, color.aqua)
    f_cell(1,  0, "v1.1",                 H, S)
    f_cell(0,  1, "Ticker",               R, S)
    f_cell(1,  1, syminfo.ticker,         R, W)
    f_cell(0,  2, "Timeframe",            R, W)
    f_cell(1,  2, timeframe.period,       R, W)
    f_cell(0,  3, "Status",               R, S)
    f_cell(1,  3, sigStatus,              sBg(sigStatus), W)
    f_cell(0,  4, "Score",                R, S)
    f_cell(1,  4, str.tostring(score) + "/5", score >= i_minScore ? OK : FL, W)
    f_cell(0,  5, "Entry",                R, S)
    f_cell(1,  5, inTrade ? str.tostring(entryPrice, format.mintick) : "--", R, W)
    f_cell(0,  6, "Stop",                 R, S)
    f_cell(1,  6, inTrade ? str.tostring(stopLevel,  format.mintick) : "--", R, color.red)
    f_cell(0,  7, "TP1 (40%)",            R, S)
    f_cell(1,  7, inTrade ? str.tostring(tp1Level,   format.mintick) : "--", R, color.lime)
    f_cell(0,  8, "TP2 (40%)",            R, S)
    f_cell(1,  8, inTrade ? str.tostring(tp2Level,   format.mintick) : "--", R, color.lime)
    f_cell(0,  9, "TP3 (20%)",            R, S)
    f_cell(1,  9, inTrade ? str.tostring(tp3Level,   format.mintick) : "--", R, color.teal)
    f_cell(0, 10, "R:R",                  R, S)
    f_cell(1, 10, not na(rrRatio) ? str.tostring(rrRatio, "#.##") + ":1" : "--", R, W)
    f_cell(0, 11, "Bars",                 R, S)
    f_cell(1, 11, inTrade ? str.tostring(tradeBarNum) + "/" + str.tostring(i_maxBarsInTrade) : "--", tradeBarNum >= i_maxBarsInTrade - 5 ? WN : R, W)
    f_cell(0, 12, "Trailing",             R, S)
    f_cell(1, 12, inTrade ? (tp2Fired ? "ACTIVE" : "OFF") : "--", tp2Fired ? OK : R, W)
    f_cell(0, 13, "HTF Trend",            R, S)
    f_cell(1, 13, htfBullish  ? "PASS" : "FAIL", htfBullish  ? OK : FL, W)
    f_cell(0, 14, "EMA 200",              R, S)
    f_cell(1, 14, ema200Pass  ? "PASS" : "FAIL", ema200Pass  ? OK : FL, W)
    f_cell(0, 15, "ATR Filter",           R, S)
    f_cell(1, 15, atrFilter   ? "PASS" : "FAIL", atrFilter   ? OK : FL, W)
    f_cell(0, 16, "R:R Filter",           R, S)
    f_cell(1, 16, rrFilter    ? "PASS" : "FAIL", rrFilter    ? OK : FL, W)
    f_cell(0, 17, "Weekend",              R, S)
    f_cell(1, 17, isWeekend   ? "ON"   : "OFF", isWeekend   ? WN : R, W)
    f_cell(0, 18, "Funding Rate",         R, S)
    f_cell(1, 18, str.tostring(i_funding * 100.0, "#.###") + "%", i_funding > 0.001 ? WN : R, W)
    f_cell(0, 19, "Liq. Estimate",        R, S)
    f_cell(1, 19, inTrade ? str.tostring(liqEst, format.mintick) : "--", R, color.orange)
    f_cell(0, 20, "Pos. Size",            R, S)
    f_cell(1, 20, not na(posSize) ? str.tostring(posSize, "#.####") : "--", R, W)
    f_cell(0, 21, "ATR",                  R, S)
    f_cell(1, 21, str.tostring(atr, format.mintick), R, W)
    f_cell(0, 22, "Bot Status",           R, S)
    f_cell(1, 22, "CONNECTED",            OK, W)

// ── ALERT CONDITIONS ────────────────────────────────────────────────
alertcondition(bearTrapSignal, "BUY_SIGNAL", "Bear Trap: BUY SIGNAL")
alertcondition(tp1Signal,      "TP1_HIT",    "Bear Trap: TP1 HIT")
alertcondition(tp2Signal,      "TP2_HIT",    "Bear Trap: TP2 HIT")
alertcondition(exitSignal,     "EXIT_TRADE", "Bear Trap: EXIT")

// ── WEBHOOK PAYLOAD ─────────────────────────────────────────────────
alertBody(sig) =>
    string rrStr = not na(rrRatio)   ? str.tostring(rrRatio,   "#.##")         : "0"
    string slStr = not na(stopLevel) ? str.tostring(stopLevel, format.mintick) : "0"
    string t1Str = not na(tp1Level)  ? str.tostring(tp1Level,  format.mintick) : "0"
    string t2Str = not na(tp2Level)  ? str.tostring(tp2Level,  format.mintick) : "0"
    string t3Str = not na(tp3Level)  ? str.tostring(tp3Level,  format.mintick) : "0"
    string j = '{"strategy":"Bear Trap Trade Pro",'
    j := j + '"ticker":"'      + syminfo.ticker                      + '",'
    j := j + '"timeframe":"'   + timeframe.period                    + '",'
    j := j + '"signal":"'      + sig                                 + '",'
    j := j + '"entry":'        + str.tostring(close, format.mintick) + ','
    j := j + '"stop":"'        + slStr + '",'
    j := j + '"tp1":"'         + t1Str + '",'
    j := j + '"tp2":"'         + t2Str + '",'
    j := j + '"tp3":"'         + t3Str + '",'
    j := j + '"score":"'       + str.tostring(score)                 + '",'
    j := j + '"risk_reward":"' + rrStr                               + '",'
    j := j + '"trailing":"'    + (tp2Fired   ? "true" : "false")    + '",'
    j := j + '"htf_trend":"'   + (htfBullish ? "BULL" : "BEAR")     + '",'
    j := j + '"ema_filter":"'  + (ema200Pass ? "PASS" : "FAIL")     + '",'
    j := j + '"order_type":"'  + i_orderType                        + '",'
    j := j + '"timestamp":"{{time}}"}'
    j

if bearTrapSignal
    alert(alertBody("BUY_SIGNAL"), alert.freq_once_per_bar_close)
if tp1Signal
    alert(alertBody("TP1_HIT"),    alert.freq_once_per_bar_close)
if tp2Signal
    alert(alertBody("TP2_HIT"),    alert.freq_once_per_bar_close)
if exitSignal
    alert(alertBody("EXIT_TRADE"), alert.freq_once_per_bar_close)
