//@version=5
// ═══════════════════════════════════════════════════════════════════
//  Bear Trap Trade Pro — Backtest
//  Load this file in TradingView → Pine Editor → Add to chart.
//  Open the "Strategy Tester" tab to see performance metrics.
//  Change inputs (Min Score, HTF Filter, EMA 200 Filter, etc.) and
//  the Strategy Tester updates instantly — no re-add required.
//
//  Partial exit model:
//    TP1 (1R) → close 40 % of position, stop moves to breakeven
//    TP2 (2R) → close 40 % of original (~67 % of remaining)
//    TP3 (3R) → close remaining 20 %
//    Stop     → close 100 % of remaining at stop level
//
//  Entry fills at the OPEN of the bar AFTER the signal bar
//  (default Pine Script strategy behaviour). This is realistic —
//  you see the signal at bar close and your order fills next open.
// ═══════════════════════════════════════════════════════════════════
strategy("Bear Trap Trade Pro — Backtest", overlay=true,
         initial_capital    = 10000,
         default_qty_type   = strategy.fixed,
         default_qty_value  = 1,
         commission_type    = strategy.commission.percent,
         commission_value   = 0.05,
         slippage           = 2,
         pyramiding         = 0,
         max_labels_count   = 500,
         max_lines_count    = 500)

// ── INPUTS ────────────────────────────────────────────────────────
i_pivotLeft    = input.int(10,    "Pivot Left",        minval=2,  maxval=50,  group="Bear Trap")
i_pivotRight   = input.int(10,    "Pivot Right",       minval=2,  maxval=50,  group="Bear Trap")
i_allowWick    = input.bool(true, "Allow Wick Sweep",                          group="Bear Trap")
i_minScore     = input.int(3,     "Min Score (1-5)",   minval=1,  maxval=5,   group="Bear Trap")
i_htfFilter    = input.bool(true,       "HTF Filter",                          group="Filters")
i_htfTf        = input.timeframe("240", "HTF Timeframe",                       group="Filters")
i_ema200Filter = input.bool(true,       "EMA 200 Filter",                      group="Filters")
i_atrLen       = input.int(14,    "ATR Length",         minval=1,              group="Levels")
i_atrSlBuf     = input.float(0.5, "ATR SL Buffer",      minval=0.1, step=0.1, group="Levels")
i_tp1R         = input.float(1.0, "TP1 R-Multiple",     minval=0.5, step=0.1, group="Levels")
i_tp2R         = input.float(2.0, "TP2 R-Multiple",     minval=1.0, step=0.1, group="Levels")
i_volLen       = input.int(20,    "Vol Avg Length",     minval=5,              group="Confluence")
i_volMult      = input.float(1.5, "Vol Spike Mult",     minval=1.0, step=0.1, group="Confluence")
i_riskPct      = input.float(2.0, "Risk % per trade",   minval=0.1, maxval=10, group="Risk")
i_funding      = input.float(0.0, "Funding Rate %",     step=0.001,            group="Risk")

// ── CORE INDICATORS ───────────────────────────────────────────────
atr    = ta.atr(i_atrLen)
ema200 = ta.ema(close, 200)
volAvg = ta.sma(volume, i_volLen)

htfClose   = request.security(syminfo.tickerid, i_htfTf, close[1],             lookahead=barmerge.lookahead_off)
htfEma200  = request.security(syminfo.tickerid, i_htfTf, ta.ema(close,200)[1], lookahead=barmerge.lookahead_off)
htfBullish = htfClose > htfEma200

rawPivotLow  = ta.pivotlow(low,   i_pivotLeft, i_pivotRight)
rawPivotHigh = ta.pivothigh(high, i_pivotLeft, i_pivotRight)

var float lastPivotLow  = na
var int   lastPivotBar  = na
var float lastPivotHigh = na

if not na(rawPivotLow)
    lastPivotLow := rawPivotLow
    lastPivotBar := bar_index - i_pivotRight

if not na(rawPivotHigh)
    lastPivotHigh := rawPivotHigh

cvdProxy(o, h, l, c, v) =>
    r = h - l
    r > 0.0 ? ((c - l) - (h - c)) / r * v : 0.0

cvd1 = cvdProxy(open[1], high[1], low[1], close[1], volume[1])
cvd2 = cvdProxy(open[2], high[2], low[2], close[2], volume[2])

// ── SIGNAL ────────────────────────────────────────────────────────
validPivot    = not na(lastPivotLow) and bar_index > lastPivotBar + 1
wickSweep     = validPivot and low[1]   < lastPivotLow and close[1] > lastPivotLow
closeSweep    = validPivot and close[2] < lastPivotLow and close[1] > lastPivotLow
bearTrapSetup = (i_allowWick ? wickSweep : closeSweep) and close > open and close > lastPivotLow

ema200Pass = close > ema200
htfPass    = not i_htfFilter    or htfBullish
ema200Gate = not i_ema200Filter or ema200Pass

scoreRaw = (htfBullish ? 1 : 0) + (ema200Pass ? 1 : 0) + (volume[1] > volAvg[1] * i_volMult ? 1 : 0) + (atr > atr[1] ? 1 : 0) + (low[1] < low[2] and cvd1 > cvd2 ? 1 : 0)
score    = math.max(0, scoreRaw - (i_funding > 0.001 ? 1 : 0))

bearTrapSignal = bearTrapSetup and score >= i_minScore and htfPass and ema200Gate

// ── TRADE EXECUTION ───────────────────────────────────────────────
// Level state is set on the signal bar and used from the next bar onward.
// s_sl is mutable: moves to breakeven after TP1.
var float s_entry  = na
var float s_sl     = na
var float s_tp1    = na
var float s_tp2    = na
var float s_tp3    = na
var bool  s_t1Done = false
var bool  s_t2Done = false

inTrade = strategy.position_size > 0

if bearTrapSignal and not inTrade
    s_entry  := close
    s_sl     := low[1] - atr * i_atrSlBuf
    float risk = s_entry - s_sl
    s_tp1    := s_entry + risk * i_tp1R
    s_tp2    := s_entry + risk * i_tp2R
    s_tp3    := s_entry + risk * 3.0
    s_t1Done := false
    s_t2Done := false
    float qty = risk > 0 ? (strategy.equity * i_riskPct / 100.0) / risk : 1.0
    strategy.entry("Long", strategy.long, qty=qty)

if inTrade
    // TP1 — close 40 %, move stop to breakeven
    if not s_t1Done and high >= s_tp1
        strategy.close("Long", qty_percent=40, comment="TP1")
        s_sl     := s_entry
        s_t1Done := true
    // TP2 — close 40 % of original (67 % of remaining 60 %)
    if s_t1Done and not s_t2Done and high >= s_tp2
        strategy.close("Long", qty_percent=67, comment="TP2")
        s_t2Done := true
    // Stop — close all; else-if prevents double-close if low=stop & high=TP3
    if low <= s_sl
        strategy.close("Long", comment="Stop")
        s_entry  := na
        s_sl     := na
        s_tp1    := na
        s_tp2    := na
        s_tp3    := na
        s_t1Done := false
        s_t2Done := false
    else if high >= s_tp3
        strategy.close("Long", comment="TP3")
        s_entry  := na
        s_sl     := na
        s_tp1    := na
        s_tp2    := na
        s_tp3    := na
        s_t1Done := false
        s_t2Done := false

// ── OVERLAYS ──────────────────────────────────────────────────────
plot(ema200,       "EMA 200",   color=color.new(color.yellow, 0), linewidth=2)
plot(lastPivotLow, "Swing Low", color=color.new(color.red, 60),   style=plot.style_cross)

if bearTrapSignal
    label.new(bar_index, low[1] * 0.9995, "TRAP " + str.tostring(score) + "/5",
              style=label.style_label_up, color=color.new(color.green, 15), textcolor=color.white, size=size.small)

// Level lines on each new trade
var line ln_entry = na
var line ln_sl    = na
var line ln_tp1   = na
var line ln_tp2   = na
var line ln_tp3   = na

if bearTrapSignal and not inTrade
    if not na(ln_entry)
        line.delete(ln_entry)
    if not na(ln_sl)
        line.delete(ln_sl)
    if not na(ln_tp1)
        line.delete(ln_tp1)
    if not na(ln_tp2)
        line.delete(ln_tp2)
    if not na(ln_tp3)
        line.delete(ln_tp3)
    e = bar_index + 60
    ln_entry := line.new(bar_index, s_entry, e, s_entry, color=color.blue,  width=2, style=line.style_dashed)
    ln_sl    := line.new(bar_index, s_sl,    e, s_sl,    color=color.red,   width=2, style=line.style_dashed)
    ln_tp1   := line.new(bar_index, s_tp1,   e, s_tp1,   color=color.lime,  width=1, style=line.style_dashed)
    ln_tp2   := line.new(bar_index, s_tp2,   e, s_tp2,   color=color.green, width=2, style=line.style_dashed)
    ln_tp3   := line.new(bar_index, s_tp3,   e, s_tp3,   color=color.teal,  width=1, style=line.style_dotted)
