//@version=5
// ═══════════════════════════════════════════════════════════════════
//  Bear Trap Trade Pro — Backtest Strategy  v1.1
//  Load in TradingView Pine Editor → Add to chart → Strategy Tester tab.
//
//  Target metrics before going live:
//    Trades       >= 100
//    Win rate     >= 55 %
//    Profit factor >= 1.5
//    Max drawdown  <= 10 %
//    Avg win > Avg loss
//
//  Partial exit model (fills at next bar open by default):
//    TP1 (1R) — close 40 %, stop moves to breakeven
//    TP2 (2R) — close 40 % of original (~67 % of remaining 60 %)
//    TP3 (3R) — close remaining 20 %
//    Stop     — always hard exit, no exceptions
//    Max bars — time-stop if trade lingers past i_maxBarsInTrade
//    Max loss — emergency close if unrealised loss > 1.5 x cap (gap protection)
// ═══════════════════════════════════════════════════════════════════
strategy("Bear Trap Trade Pro — Backtest", overlay=true,
         initial_capital    = 10000,
         default_qty_type   = strategy.fixed,
         default_qty_value  = 1,
         commission_type    = strategy.commission.percent,
         commission_value   = 0.05,
         slippage           = 2,
         pyramiding         = 0,
         max_labels_count   = 500,
         max_lines_count    = 500)

// ── INPUTS ────────────────────────────────────────────────────────
i_pivotLeft      = input.int(10,     "Pivot Left",           minval=2,  maxval=50,  group="Bear Trap")
i_pivotRight     = input.int(10,     "Pivot Right",          minval=2,  maxval=50,  group="Bear Trap")
i_allowWick      = input.bool(true,  "Allow Wick Sweep",                             group="Bear Trap")
i_minScore       = input.int(2,      "Min Score (1-5)",      minval=1,  maxval=5,   group="Bear Trap")
i_htfFilter      = input.bool(false,       "HTF Filter",                             group="Filters")
i_htfTf          = input.timeframe("240",  "HTF Timeframe",                          group="Filters")
i_ema200Filter   = input.bool(true,        "EMA 200 Filter",                         group="Filters")
i_minRR          = input.float(1.5,  "Min R:R",              minval=0.5, step=0.1,  group="Filters")
i_maxSlAtr       = input.float(2.0,  "Max Stop (ATR x)",     minval=0.5, step=0.1,  group="Filters")
i_atrLen         = input.int(14,     "ATR Length",           minval=1,               group="Levels")
i_atrSlBuf       = input.float(0.3,  "ATR SL Buffer",        minval=0.1, step=0.1,  group="Levels")
i_tp1R           = input.float(1.0,  "TP1 R-Multiple",       minval=0.5, step=0.1,  group="Levels")
i_tp2R           = input.float(2.0,  "TP2 R-Multiple",       minval=1.0, step=0.1,  group="Levels")
i_maxBarsInTrade = input.int(50,     "Max Bars in Trade",    minval=5,  maxval=200,  group="Risk")
i_riskPct        = input.float(2.0,  "Risk % per trade",     minval=0.1, maxval=10,  group="Risk")
i_maxLossPct     = input.float(1.5,  "Max Loss Cap %",       minval=0.1, maxval=10,  group="Risk")
i_volLen         = input.int(20,     "Vol Avg Length",       minval=5,               group="Confluence")
i_volMult        = input.float(1.5,  "Vol Spike Mult",       minval=1.0, step=0.1,  group="Confluence")
i_funding        = input.float(0.0,  "Funding Rate %",       step=0.001,             group="Confluence")

// ── CORE INDICATORS ───────────────────────────────────────────────
atr    = ta.atr(i_atrLen)
ema200 = ta.ema(close, 200)
volAvg = ta.sma(volume, i_volLen)

htfClose   = request.security(syminfo.tickerid, i_htfTf, close[1],             lookahead=barmerge.lookahead_off)
htfEma200  = request.security(syminfo.tickerid, i_htfTf, ta.ema(close,200)[1], lookahead=barmerge.lookahead_off)
htfBullish = htfClose > htfEma200

rawPivotLow  = ta.pivotlow(low,   i_pivotLeft, i_pivotRight)
rawPivotHigh = ta.pivothigh(high, i_pivotLeft, i_pivotRight)

var float lastPivotLow  = na
var int   lastPivotBar  = na
var float lastPivotHigh = na

if not na(rawPivotLow)
    lastPivotLow := rawPivotLow
    lastPivotBar := bar_index - i_pivotRight

if not na(rawPivotHigh)
    lastPivotHigh := rawPivotHigh

cvdProxy(o, h, l, c, v) =>
    r = h - l
    r > 0.0 ? ((c - l) - (h - c)) / r * v : 0.0

cvd1 = cvdProxy(open[1], high[1], low[1], close[1], volume[1])
cvd2 = cvdProxy(open[2], high[2], low[2], close[2], volume[2])

// ── SIGNAL ────────────────────────────────────────────────────────
validPivot    = not na(lastPivotLow) and bar_index > lastPivotBar + 1
wickSweep     = validPivot and low[1]   < lastPivotLow and close[1] > lastPivotLow
closeSweep    = validPivot and close[2] < lastPivotLow and close[1] > lastPivotLow
bearTrapSetup = (i_allowWick ? wickSweep : closeSweep) and close > open and close > lastPivotLow

ema200Pass = close > ema200
htfPass    = not i_htfFilter    or htfBullish
ema200Gate = not i_ema200Filter or ema200Pass

scoreRaw = (htfBullish ? 1 : 0) + (ema200Pass ? 1 : 0) + (volume[1] > volAvg[1] * i_volMult ? 1 : 0) + (atr > atr[1] ? 1 : 0) + (low[1] < low[2] and cvd1 > cvd2 ? 1 : 0)
score    = math.max(0, scoreRaw - (i_funding > 0.001 ? 1 : 0))

// Pre-entry filters
prospSl   = low[1] - atr * i_atrSlBuf
prospRisk = close - prospSl
prospTp1  = not na(lastPivotHigh) and lastPivotHigh > close and lastPivotHigh < close + prospRisk * 2.0 ? lastPivotHigh : close + prospRisk * i_tp1R
atrFilter = prospRisk > 0 and prospRisk <= i_maxSlAtr * atr
rrFilter  = prospRisk > 0 and (prospTp1 - close) / prospRisk >= i_minRR

bearTrapSignal = bearTrapSetup and score >= i_minScore and htfPass and ema200Gate and atrFilter and rrFilter

// ── TRADE EXECUTION ───────────────────────────────────────────────
var float s_entry   = na
var float s_sl      = na
var float s_tp1     = na
var float s_tp2     = na
var float s_tp3     = na
var bool  s_t1Done  = false
var bool  s_t2Done  = false
var int   s_barNum  = 0

inTrade = strategy.position_size > 0

if bearTrapSignal and not inTrade
    s_entry  := close
    s_sl     := low[1] - atr * i_atrSlBuf
    float risk = s_entry - s_sl
    s_tp1    := not na(lastPivotHigh) and lastPivotHigh > s_entry and lastPivotHigh < s_entry + risk * 2.0 ? lastPivotHigh : s_entry + risk * i_tp1R
    s_tp2    := not na(lastPivotHigh) and lastPivotHigh > s_tp1 ? lastPivotHigh : s_entry + risk * i_tp2R
    s_tp3    := s_entry + risk * 3.0
    s_t1Done := false
    s_t2Done := false
    s_barNum := 0
    float effRisk = math.min(i_riskPct, i_maxLossPct)
    float qty     = risk > 0 ? (strategy.equity * effRisk / 100.0) / risk : 1.0
    strategy.entry("Long", strategy.long, qty=qty)

if inTrade
    s_barNum += 1

    // TP1 — close 40 %, move stop to breakeven
    if not s_t1Done and not na(s_tp1) and high >= s_tp1
        strategy.close("Long", qty_percent=40, comment="TP1")
        s_sl     := s_entry
        s_t1Done := true

    // TP2 — close 40 % of original (~67 % of remaining 60 %)
    if s_t1Done and not s_t2Done and not na(s_tp2) and high >= s_tp2
        strategy.close("Long", qty_percent=67, comment="TP2")
        s_t2Done := true

    // Trailing stop: ratchet under higher lows after TP2
    if s_t2Done and not na(low[1])
        float trail = low[1] - atr * i_atrSlBuf
        if trail > s_sl
            s_sl := trail

    // Hard stop — no exceptions
    if not na(s_sl) and low <= s_sl
        strategy.close("Long", comment="Stop")
        s_entry  := na
        s_sl     := na
        s_tp1    := na
        s_tp2    := na
        s_tp3    := na
        s_t1Done := false
        s_t2Done := false
        s_barNum := 0
    // TP3 — close remainder
    else if not na(s_tp3) and high >= s_tp3
        strategy.close("Long", comment="TP3")
        s_entry  := na
        s_sl     := na
        s_tp1    := na
        s_tp2    := na
        s_tp3    := na
        s_t1Done := false
        s_t2Done := false
        s_barNum := 0
    // Max bars timeout
    else if s_barNum >= i_maxBarsInTrade
        strategy.close("Long", comment="Max Bars")
        s_entry  := na
        s_sl     := na
        s_tp1    := na
        s_tp2    := na
        s_tp3    := na
        s_t1Done := false
        s_t2Done := false
        s_barNum := 0
    // Emergency max loss (gap protection: 1.5 x cap)
    else if strategy.openprofit < -(strategy.equity * i_maxLossPct * 1.5 / 100.0)
        strategy.close("Long", comment="Max Loss")
        s_entry  := na
        s_sl     := na
        s_tp1    := na
        s_tp2    := na
        s_tp3    := na
        s_t1Done := false
        s_t2Done := false
        s_barNum := 0

// ── OVERLAYS ──────────────────────────────────────────────────────
plot(ema200,       "EMA 200",   color=color.new(color.yellow, 0), linewidth=2)
plot(lastPivotLow, "Swing Low", color=color.new(color.red, 60),   style=plot.style_cross)

if bearTrapSignal
    label.new(bar_index, low[1] * 0.9995, "TRAP " + str.tostring(score) + "/5",
              style=label.style_label_up, color=color.new(color.green, 15), textcolor=color.white, size=size.small)

var line ln_entry = na
var line ln_sl    = na
var line ln_tp1   = na
var line ln_tp2   = na
var line ln_tp3   = na

if bearTrapSignal and not inTrade
    if not na(ln_entry)
        line.delete(ln_entry)
    if not na(ln_sl)
        line.delete(ln_sl)
    if not na(ln_tp1)
        line.delete(ln_tp1)
    if not na(ln_tp2)
        line.delete(ln_tp2)
    if not na(ln_tp3)
        line.delete(ln_tp3)
    e = bar_index + 60
    ln_entry := line.new(bar_index, s_entry, e, s_entry, color=color.blue,  width=2, style=line.style_dashed)
    ln_sl    := line.new(bar_index, s_sl,    e, s_sl,    color=color.red,   width=2, style=line.style_dashed)
    ln_tp1   := line.new(bar_index, s_tp1,   e, s_tp1,   color=color.lime,  width=1, style=line.style_dashed)
    ln_tp2   := line.new(bar_index, s_tp2,   e, s_tp2,   color=color.green, width=2, style=line.style_dashed)
    ln_tp3   := line.new(bar_index, s_tp3,   e, s_tp3,   color=color.teal,  width=1, style=line.style_dotted)

// ── ALERT CONDITIONS ──────────────────────────────────────────────
alertcondition(bearTrapSignal, "BUY_SIGNAL", "Bear Trap: BUY SIGNAL")
